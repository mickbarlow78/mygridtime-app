# -------------------------------------------------------
# MyGridTime — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# -------------------------------------------------------

# Supabase (local dev — copy values from `npx supabase start` output)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-here

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------------------
# Variables below are used in later phases.
# Leave blank until the relevant phase is being built.
# -------------------------------------------------------

# Phase 5 — Resend (transactional email)
RESEND_API_KEY=

# Phase 7a — Web Push (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Phase 7b — Claude Vision API (AI timetable extraction)
ANTHROPIC_API_KEY=

# Phase 7c — Twilio (SMS + WhatsApp alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Phase 7c — Stripe (subscription payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
